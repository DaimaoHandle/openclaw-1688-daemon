# Optional: explicitly point to OpenClaw config
KF1688_OPENCLAW_CONFIG_PATH=/home/youruser/.openclaw/openclaw.json

# Optional: if playwright-core is not available via normal require('playwright-core')
KF1688_PLAYWRIGHT_CORE_PATH=/absolute/path/to/playwright-core
# or
PLAYWRIGHT_CORE_PATH=/absolute/path/to/playwright-core

# Browser relay / CDP
KF1688_RELAY_URL=ws://127.0.0.1:18792/cdp
KF1688_RELAY_PORT=18792

# OpenClaw endpoints
KF1688_GATEWAY_URL=http://127.0.0.1:18789/v1/chat/completions
KF1688_TOOLS_INVOKE_URL=http://127.0.0.1:18789/tools/invoke
KF1688_AGENT_ID=main

# Runtime tuning
KF1688_POLL_MS=15000
KF1688_MAX_CONTEXT_MESSAGES=6

# One or more shop names, comma-separated or JSON array string
KF1688_SHOP_NAMES=极有光世界百货
# Example JSON array:
# KF1688_SHOP_NAMES=["店铺A","店铺B"]

# Optional Feishu notify target. Leave empty to disable human notification.
KF1688_NOTIFY_TARGET=
